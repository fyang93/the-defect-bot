{
  "name": "the-defect-bot",
  "private": true,
  "type": "module",
  "packageManager": "npm@10",
  "scripts": {
    "opencode": "opencode",
    "opencode:run": "opencode run",
    "repo:cli": "tsx --tsconfig tsconfig.json src/cli.ts",
    "bot": "tsx --tsconfig tsconfig.json src/bot/main.ts",
    "dev": "tsx watch --tsconfig tsconfig.json src/bot/main.ts",
    "check": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:nl": "vitest run tests/nl-regression.test.ts",
    "test:live": "tsx --tsconfig tsconfig.json tests/live-assistant.ts"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@opencode-ai/sdk": "^1.3.7",
    "dotenv": "^17.2.3",
    "grammy": "^1.41.1",
    "markdown-it": "^14.1.1",
    "ntp-time-sync": "^0.5.0",
    "solarlunar": "^3.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.5.0",
    "opencode-ai": "^1.3.7",
    "tsx": "^4.20.6",
    "typescript": "^6.0.2",
    "vitest": "^3.2.4"
  }
}
