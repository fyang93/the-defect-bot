[telegram]
bot_token = "YOUR_TELEGRAM_BOT_TOKEN"
# Bootstrap admin user. Durable user roles live in system/users.json.
admin_user_id = 333333333
waiting_messages = ["机宝启动中..."]
waiting_message_rotation_seconds = 5
input_merge_window_seconds = 3
menu_page_size = 8

[bot]
persona_style = "Speak like the Defect from Slay the Spire."
# Choose "zh-CN" or "en"
language = "zh-CN"
default_timezone = "Asia/Tokyo"

[maintenance]
enabled = true
idle_after_minutes = 15
